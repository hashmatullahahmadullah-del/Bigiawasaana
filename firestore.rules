rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'bigiawasaana@gmail.com';
    }

    function isKds() {
      return request.auth != null && request.auth.token.kds == true;
    }

    function isAdminOrKds() {
      return isAdmin() || isKds();
    }
    
    // Menu Collection: Public read, Authenticated Admin write
    match /menu/{item} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Orders Collection
    match /orders/{order} {
      // Orders are created securely via the Cloud Function. Client creation is forbidden.
      allow create: if false;
      
      // Anyone can read a SINGLE order (for tracking page)
      // But listing ALL orders requires admin or kds
      allow get: if true;
      allow list: if isAdminOrKds();
      
      // Only admins or KDS can update or delete
      // Allow status changes OR kdsHidden toggle (used by KDS dismiss button)
      allow update: if isAdminOrKds()
        && (request.resource.data.status in ['pending', 'preparing', 'ready', 'completed', 'scheduled', 'canceled']
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kdsHidden', 'updatedAt']));
            
      allow delete: if isAdmin();
    }

    // Settings Collection
    match /settings/{doc} {
      allow read: if doc == 'pickupConfig' || doc == 'popup' || isAdmin();
      allow write: if isAdmin();
    }
    
    // Live Stats
    match /liveStats/{doc} {
      allow read: if doc == 'current' || isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Catering Inquiries Collection
    match /catering_inquiries/{inquiry} {
      allow create: if true; // Anyone can submit an inquiry
      allow read, update, delete: if isAdmin(); // Only admins can view and manage
    }
    
    // Deals Collection
    match /deals/{deal} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Service Areas Collection (Local SEO)
    match /serviceAreas/{area} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog Posts Collection
    match /posts/{post} {
      allow read: if true; // Or we can restrict to published only, but UI filters it anyway
      allow write: if isAdmin(); // Only admins can create/edit posts
    }
    
    // Analytics Page Views Collection
    match /page_views/{view} {
      // Anyone can log a page view
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Expenses
    match /expenses/{id} {
      allow read, write: if isAdmin();
    }
    
    // Inventory and Unit Economics (Admin Only)
    match /inventory/{id} {
      allow read, write: if isAdmin();
    }
    match /unitEconomics_ingredients/{id} {
      allow read, write: if isAdmin();
    }
    match /unitEconomics_events/{id} {
      allow read, write: if isAdmin();
    }
    match /unitEconomics_platforms/{id} {
      allow read, write: if isAdmin();
    }
    match /sales_logs/{id} {
      allow read, write: if isAdmin();
    }
    
    // Reviews
    match /reviews/{id} {
      // Anyone can read reviews
      allow read: if true;
      // Anyone can submit a review
      allow create: if true;
      // Only admins can edit or delete them
      allow update, delete: if isAdmin(); 
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
