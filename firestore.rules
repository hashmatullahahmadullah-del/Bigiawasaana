rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Menu Collection: Public read, Authenticated Admin write
    match /menu/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Orders Collection
    match /orders/{order} {
      // Anyone can create a validated order
      allow create: if
        request.resource.data.keys().hasAll(['items', 'total', 'status', 'createdAt', 'customerName', 'prepTime'])
        && request.resource.data.status == 'pending'
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && request.resource.data.total is string
        && request.resource.data.customerName is string
        && request.resource.data.prepTime is number;
      
      // Anyone can read a SINGLE order (for tracking page)
      // But listing ALL orders requires auth
      allow get: if true;
      allow list: if request.auth != null;
      
      // Only authenticated admins can update or delete
      allow update: if request.auth != null
        && request.resource.data.status in ['pending', 'preparing', 'ready', 'completed'];
      allow delete: if request.auth != null;
    }

    // Settings Collection
    match /settings/{doc} {
      allow read: if doc == 'pickupConfig' || request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Live Stats
    match /liveStats/{doc} {
      allow read: if doc == 'current' || request.auth != null;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Catering Inquiries Collection
    match /catering_inquiries/{inquiry} {
      allow create: if true; // Anyone can submit an inquiry
      allow read, update, delete: if request.auth != null; // Only admins can view and manage
    }
    
    // Deals Collection
    match /deals/{deal} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
