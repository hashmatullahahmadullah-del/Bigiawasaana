rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Menu Collection: Public read, Authenticated Admin write
    match /menu/{item} {
      allow read: if true;
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow write: if request.auth != null;
    }
    
    // Orders Collection
    match /orders/{order} {
      // Orders are created securely via the Cloud Function. Client creation is forbidden.
      allow create: if false;
      
      // Anyone can read a SINGLE order (for tracking page)
      // But listing ALL orders requires auth
      allow get: if true;
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow list: if request.auth != null;
      
      // Only authenticated admins can update or delete
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow update: if request.auth != null
        && request.resource.data.status in ['pending', 'preparing', 'ready', 'completed'];
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow delete: if request.auth != null;
    }

    // Settings Collection
    match /settings/{doc} {
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow read: if doc == 'pickupConfig' || doc == 'popup' || request.auth != null;
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow write: if request.auth != null;
    }
    
    // Live Stats
    match /liveStats/{doc} {
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow read: if doc == 'current' || request.auth != null;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Catering Inquiries Collection
    match /catering_inquiries/{inquiry} {
      allow create: if true; // Anyone can submit an inquiry
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow read, update, delete: if request.auth != null; // Only admins can view and manage
    }
    
    // Deals Collection
    match /deals/{deal} {
      allow read: if true;
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow write: if request.auth != null;
    }

    // Service Areas Collection (Local SEO)
    match /serviceAreas/{area} {
      allow read: if true;
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow write: if request.auth != null;
    }

    // Blog Posts Collection
    match /posts/{post} {
      allow read: if true; // Or we can restrict to published only, but UI filters it anyway
      allow write: if request.auth != null; // Only admins can create/edit posts
    }
    
    // Analytics Page Views Collection
    match /page_views/{view} {
      // Anyone can log a page view
      allow create: if true;
      // Only authenticated admins can read, update, or delete views
      // TODO: SECURITY - If customer accounts are added, change this to require custom admin claims instead of just checking if logged in
      allow read, update, delete: if request.auth != null;
    }
    
    // Expenses
    match /expenses/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Inventory and Unit Economics (Admin Only)
    match /inventory/{id} {
      allow read, write: if request.auth != null;
    }
    match /unitEconomics_ingredients/{id} {
      allow read, write: if request.auth != null;
    }
    match /unitEconomics_events/{id} {
      allow read, write: if request.auth != null;
    }
    match /unitEconomics_platforms/{id} {
      allow read, write: if request.auth != null;
    }
    match /sales_logs/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Reviews
    match /reviews/{id} {
      // Anyone can read reviews
      allow read: if true;
      // Depending on your auth model, anyone might submit reviews, or only admins can manage them
      // Assuming users submit reviews publicly without auth for now (or adjust as needed)
      allow write: if true; 
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
