{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "functions/**",
      "node_modules/**",
      ".git/**",
      "admin.js",
      "admin.html",
      "login.html",
      "display.html",
      "display.js"
    ],
    "headers": [
      {
        "source": "/.well-known/**",
        "headers": [
          { "key": "Content-Type", "value": "application/octet-stream" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/sitemap.xml", "function": "renderSitemap" },
      { "source": "/areas/**", "function": "renderAreaPage" },
      { "source": "/item/**", "function": "renderItemPage" },
      { "source": "/menu", "destination": "/menu.html" },
      { "source": "/review", "destination": "/review.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
